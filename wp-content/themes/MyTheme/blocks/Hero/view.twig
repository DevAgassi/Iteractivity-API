<section id="hero-block" class="hero-section" {{ interactivity_attrs|raw }}>
    <div class="hero-content">
        <h1>{{ fields.title|striptags|e }}</h1>

        <div class="description">
            {{ fields.content }}
        </div>

        <button data-wp-on--click="actions.openModal" data-wp-text="state.buttonText">
            {{ fields.cta_text|default('Learn More') }}
        </button>
    </div>
</section>