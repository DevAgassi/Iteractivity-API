{% extends 'layouts/base.twig' %}

{% block content %}
    <h2>{{ foo }}</h2>
{{ timer_start('tease-' ~ loop.index) }}
    {% for post in posts %}
        {% include ['partials/tease-' ~ post.type ~ '.twig', 'partials/tease.twig'] %}
    {% endfor %}
{{ timer_end('tease-' ~ loop.index) }}
{% endblock %}