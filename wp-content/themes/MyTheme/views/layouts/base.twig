<!DOCTYPE html>
<html {{ site.language_attributes }}>
	{{ timer_start('head') }}
	{% block head %}
		{% include 'partials/head.twig' %}
	{% endblock %}
	{{ timer_end('head') }}
	<body class="{{ body_class }}">
		{{ function('wp_body_open') }}
		<a class="skip-link screen-reader-text" href="#content">{{ _e('Skip to content') }}</a>
		<header class="header">
			{{ timer_start('header') }}
			{% block header %}
				<div class="wrapper">
					<h1 class="hdr-logo">
						<a class="hdr-logo-link" href="{{ site.url }}">{{ site.name }}</a>
					</h1>
					<nav id="nav-main" class="nav-main">
						{% include 'partials/menu.twig' with {
                            items: menu.get_items
                        } %}
					</nav>
					<!-- #nav -->
				</div>
			{% endblock %}
			{{ timer_end('header') }}
		</header>

		<section id="content" class="content-wrapper container px-5 mx-auto">
			{% if title %}
				<h1>{{ title }}</h1>
			{% endif %}
			<div class="wrapper">
				{% block content %}
					Sorry, no content
				{% endblock %}
			</div>
		</section>
		{{ timer_start('footer') }}
		{% block footer %}
			{% include 'partials/footer.twig' %}
		{% endblock %}
		{{ function('wp_footer') }}
		{% do action('get_footer') %}
		{{ timer_end('footer') }}
		{% if vite.isHot() %}
			<script type="module" src="{{ vite.assets().client }}"></script>
		{% endif %}
	</body>
</html>
