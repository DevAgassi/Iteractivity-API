{
  "name": "acf/hero",
  "title": "HeroBlock",
  "description": "HeroBlock block",
  "category": "custom-blocks",
  "icon": "wordpress-alt",
  "apiVersion": 3,
  "supports": {
    "anchor": true,
    "customClassName": true,
    "multiple": true,
    "reusable": true,
    "jsx": false,
    "align": ["left", "center", "right", "wide", "full"],
    "interactivity": false
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    }
  },
  "acf": {
    "mode": "preview"
  }
}